# ============================================
# Sunday AI Assistant — Environment Variables
# ============================================
# Copy this to .env and fill in your keys

# --- AI Provider API Keys ---
CLAUDE_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# --- Default Provider (claude | gemini | openai) ---
DEFAULT_PROVIDER=gemini

# --- Server ---
PORT=3000

# --- Discord ---
DISCORD_ENABLED=false
DISCORD_BOT_TOKEN=

# --- Telegram ---
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=

# --- WhatsApp ---
WHATSAPP_ENABLED=false

# --- Shell Execution ---
SHELL_ENABLED=true
# Mode: allowlist (only run allowed commands) | blocklist (run anything except blocked)
SHELL_MODE=blocklist
